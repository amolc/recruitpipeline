        {
          "name": "Extract by Application ID",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/agents/extract/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "agents",
                "extract",
                ""
              ]
            },
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "application_id",
                  "value": "1",
                  "type": "text"
                }
              ]
            }
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"id\": 1,\n  \"application_id\": 1,\n  \"candidate_name\": \"John Doe\",\n  \"summary\": \"Experienced software engineer with 8+ years building scalable web applications.\",\n  \"skills\": [\n    { \"name\": \"Python\", \"category\": \"Technical\", \"level\": \"expert\" },\n    { \"name\": \"Django\", \"category\": \"Technical\", \"level\": \"expert\" },\n    { \"name\": \"JavaScript\", \"category\": \"Technical\", \"level\": \"advanced\" }\n  ],\n  \"experience\": [\n    {\n      \"company\": \"Tech Corp\",\n      \"title\": \"Senior Developer\",\n      \"start_date\": \"Jan 2020\",\n      \"end_date\": \"Present\",\n      \"description\": \"Leading backend development team.\",\n      \"technologies\": [\"Python\", \"Django\", \"PostgreSQL\"]\n    }\n  ],\n  \"education\": [\n    {\n      \"institution\": \"MIT\",\n      \"degree\": \"B.Sc\",\n      \"field\": \"Computer Science\",\n      \"graduation_year\": \"2015\",\n      \"gpa\": null\n    }\n  ],\n  \"certifications\": [\n    { \"name\": \"AWS Solutions Architect\", \"issuer\": \"Amazon\", \"year\": \"2021\" }\n  ],\n  \"languages\": [\n    { \"language\": \"English\", \"proficiency\": \"native\" }\n  ],\n  \"contact\": {\n    \"email\": \"john@example.com\",\n    \"phone\": \"+1-555-0100\",\n    \"linkedin\": \"https://linkedin.com/in/johndoe\",\n    \"location\": \"San Francisco, CA\"\n  },\n  \"total_experience_years\": 8,\n  \"extracted_at\": \"2026-07-15T12:00:00+00:00\"\n}"
            },
            {
              "name": "Application Not Found",
              "status": "Not Found",
              "code": 404,
              "body": "{\"error\": \"Application 999 not found\"}"
            },
            {
              "name": "No Text Extracted",
              "status": "Unprocessable Entity",
              "code": 422,
              "body": "{\"error\": \"Could not extract text from file\", \"raw_text\": \"[No text extracted]\"}"
            }
          ]
        },
